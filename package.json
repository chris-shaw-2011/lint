{
	"name": "@chris-shaw-2011/lint",
	"version": "0.1.0",
	"description": "Shared lint configuration and tooling for TypeScript and React workspaces.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"default": "./dist/react.js"
		},
		"./knip": {
			"types": "./dist/knip.d.ts",
			"default": "./dist/knip.js"
		}
	},
	"bin": {
		"eslint": "./dist/bin/eslint.js",
		"knip": "./dist/bin/knip.js",
		"sherif": "./dist/bin/sherif.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chris-shaw-2011/lint.git"
	},
	"bugs": {
		"url": "https://github.com/chris-shaw-2011/lint/issues"
	},
	"homepage": "https://github.com/chris-shaw-2011/lint#readme",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rimraf dist",
		"prepack": "npm run clean && npm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "node ./node_modules/eslint/bin/eslint.js .",
		"lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
		"knip": "node ./node_modules/knip/bin/knip.js --config knip.json --reporter compact",
		"knip:json": "node ./node_modules/knip/bin/knip.js --config knip.json --reporter json",
		"sherif": "node ./node_modules/sherif/index.js --ignore-rule root-package-private-field --ignore-rule root-package-dependencies",
		"publint": "publint --pack false",
		"attw": "npm_config_cache=/tmp/npm-cache-chris-shaw-lint attw --pack --profile esm-only .",
		"check": "npm run lint && npm run typecheck && npm run knip && npm run sherif && npm run publint && npm run attw",
		"test:smoke": "node --experimental-strip-types ./scripts/smoke-test.ts",
		"verify": "npm run build && npm run check && npm run test:smoke"
	},
	"dependencies": {
		"@eslint/js": "^9.39.1",
		"@eslint/markdown": "^7.5.1",
		"@stylistic/eslint-plugin": "^5.7.1",
		"eslint": "^9.39.2",
		"eslint-plugin-jsonc": "^3.1.1",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-yml": "^3.3.1",
		"globals": "^17.1.0",
		"jsonc-eslint-parser": "^3.1.0",
		"knip": "^5.82.1",
		"sherif": "^1.10.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/node": "^25.3.5",
		"publint": "^0.3.15",
		"rimraf": "^6.0.1"
	},
	"packageManager": "npm@11.6.2",
	"workspaces": [
		"."
	]
}
